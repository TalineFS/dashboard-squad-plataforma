# 
# Este arquivo é apenas um MODELO de referência.
# 
# Como configurar:
# 
# 1. NO STREAMLIT CLOUD:
#    - Vá em Settings → Secrets
#    - Cole o conteúdo abaixo (com seus valores reais)
#
# 2. LOCAL (para testes):
#    - Crie o arquivo .streamlit/secrets.toml
#    - Cole o conteúdo abaixo com seus valores reais
#    - NUNCA commite este arquivo no repositório!
#
# Como gerar o API Token:
#    1. Acesse https://id.atlassian.com/manage-profile/security/api-tokens
#    2. Clique em "Create API token"
#    3. Dê um nome (ex: "streamlit-dashboard")
#    4. Copie o token gerado
#
# ═══════════════════════════════════════════════════════════════

[jira]
email = "seu-email@tfsports.com.br"
api_token = "seu-api-token-aqui"
